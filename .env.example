# ══════════════════════════════════════════════
# Netra Fraud Detection System — Environment Variables
# ══════════════════════════════════════════════
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control!
# ══════════════════════════════════════════════

# ── Frontend: API endpoint URL ──
# The URL where the FastAPI backend is running.
# For local development, use http://localhost:7860
# For HuggingFace Spaces deployment, use your Space URL.
NETRA_API_URL=http://localhost:7860

# ── Backend: CORS allowed origins ──
# Comma-separated list of allowed frontend origins.
# Add your Streamlit frontend URL and any other trusted origins.
NETRA_CORS_ORIGINS=http://localhost:8501,http://localhost:7860,http://127.0.0.1:8501,http://127.0.0.1:7860

# ── Backend: Batch processing limits ──
# Maximum number of rows allowed in a single batch request.
# Prevents OOM from oversized CSV uploads.
NETRA_MAX_BATCH_ROWS=50000

# ── Backend: Rate limiting ──
# Default rate limits are set per-endpoint in app.py:
#   /predict          → 10/minute per IP
#   /predict/v5/batch → 5/minute per IP
#   /analytics        → 30/minute per IP
#   /dashboard        → 30/minute per IP
#   /health           → 60/minute per IP
# To customize, modify the @limiter.limit() decorators in backend/app.py.
